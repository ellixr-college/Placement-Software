# ============================================================================
#  ELLIXR — SINGLE SOURCE OF ALL CONNECTIONS
#  Copy this file to `.env` and fill in the values. One file for everything:
#  Prisma, the NestJS API, and the Next.js web app all read from here.
#
#    cp .env.example .env
#
#  `.env` is gitignored — never commit real secrets.
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE — Supabase Postgres   [used by: Prisma + API]
# Supabase Dashboard → Project Settings → Database → Connection string → URI.
# Keep connection_limit low (free tier gives ~60 connections total).
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require&connection_limit=3&pool_timeout=10"
# Optional override if you can't edit the connection string directly.
PRISMA_CONNECTION_LIMIT=""

# ----------------------------------------------------------------------------
# API SERVER                      [used by: apps/api]
# ----------------------------------------------------------------------------
NODE_ENV="development"
PORT="4000"
# Origin of the web app, used for CORS. Match where Next.js runs.
WEB_ORIGIN="http://localhost:3000"
# Set to "true" in production (HTTPS) so the refresh cookie is Secure.
COOKIE_SECURE="false"

# ----------------------------------------------------------------------------
# JWT SECRETS                     [used by: apps/api]
# Generate each with:  openssl rand -base64 48
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"

# ----------------------------------------------------------------------------
# SEED — initial Platform Admin   [used by: pnpm db:seed]
# ----------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@ellixr.app"
SEED_ADMIN_PASSWORD="change-me-to-a-strong-password"

# ----------------------------------------------------------------------------
# STORAGE — Vercel Blob           [used by: apps/api]
# Token from Vercel Dashboard → Storage → your Blob store → Settings.
# Job PDFs and offer letters are stored under the "job-storage/" prefix;
# résumés are stored under the "resume-storage/" prefix.
# If résumés live in a dedicated public Blob store (recommended), set
# BLOB_RESUME_STORE_ID to that store's ID so uploads target it. Without it,
# @vercel/blob falls back to the default store linked to BLOB_READ_WRITE_TOKEN.
# ----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=""
BLOB_RESUME_STORE_ID=""

# ----------------------------------------------------------------------------
# STORAGE — Cloudflare R2         [DEFERRED — not used in V1]
# `packages/storage` keeps a dormant interface stub. Re-add these keys only if
# a future feature needs R2 instead of Vercel Blob.
# ----------------------------------------------------------------------------
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="ellixr"
# R2_PUBLIC_URL=""

# ----------------------------------------------------------------------------
# EMAIL — PROVIDER TBD            [Phase 4 — decided at END of build]
# Requirement: automated mail must send from each college's OWN email identity,
# so this will likely be per-college SMTP (their Google Workspace / M365), NOT a
# single Resend domain. Email goes behind a pluggable sender interface; leave blank.
# ----------------------------------------------------------------------------
# EMAIL_PROVIDER=""        # smtp | resend | ... (chosen later)
# EMAIL_FROM=""

# ----------------------------------------------------------------------------
# MONITORING — Sentry             [used by: Phase 5, optional]
# ----------------------------------------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ----------------------------------------------------------------------------
# WEB APP                         [used by: apps/web]
# The browser calls the same-origin BFF proxy ("/api/v1"); Next forwards it to
# API_PROXY_TARGET server-side. Keep NEXT_PUBLIC_API_URL relative so cookies are
# first-party. In prod, point API_PROXY_TARGET at the deployed API origin.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="/api/v1"
API_PROXY_TARGET="http://localhost:4000"
