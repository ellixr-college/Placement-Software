{
  "name": "ellixr",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @ellixr/database generate",
    "db:push": "dotenv -e .env -- pnpm --filter @ellixr/database push",
    "db:migrate": "dotenv -e .env -- pnpm --filter @ellixr/database migrate",
    "db:migrate:deploy": "dotenv -e .env -- pnpm --filter @ellixr/database migrate:deploy",
    "db:seed": "dotenv -e .env -- pnpm --filter @ellixr/database seed",
    "db:studio": "dotenv -e .env -- pnpm --filter @ellixr/database studio"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
