// Ellixr — Prisma schema
// Phase 1: multi-tenant foundation, users, auth tokens.
// Models map to snake_case tables. Later phases extend this file.

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_ADMIN
  COLLEGE_ADMIN
  PLACEMENT_OFFICER
  STUDENT
}

enum SubscriptionPlan {
  TRIAL
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

// A course offered by a college (e.g. "B.Tech"), with its branches/specialisations
// (e.g. ["CSE","ECE","Mechanical"]). Managed by the Platform Admin. Student
// course/branch and job eligibleCourses/eligibleBranches reference these names.
model CollegeCourse {
  id        String   @id @default(uuid())
  collegeId String   @map("college_id")
  name      String
  branches  String[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  college College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([collegeId, name])
  @@index([collegeId])
  @@map("college_courses")
}

model College {
  id                 String             @id @default(uuid())
  name               String
  slug               String             @unique
  domain             String?
  logoUrl            String?            @map("logo_url")
  contactEmail       String             @map("contact_email")
  contactPhone       String?            @map("contact_phone")
  address            String?
  city               String?
  state              String?
  country            String             @default("India")
  subscriptionPlan   SubscriptionPlan   @default(TRIAL) @map("subscription_plan")
  subscriptionStatus SubscriptionStatus @default(TRIAL) @map("subscription_status")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  users    User[]
  students Student[]
  courses  CollegeCourse[]

  @@map("colleges")
}

model User {
  id              String    @id @default(uuid())
  collegeId       String?   @map("college_id") // null for PLATFORM_ADMIN
  email           String    @unique
  passwordHash    String    @map("password_hash")
  fullName        String    @map("full_name")
  role            UserRole
  phone           String?
  avatarUrl       String?   @map("avatar_url")
  isActive           Boolean   @default(true) @map("is_active")
  // The designated College Head (placement head/HOD): a COLLEGE_ADMIN who can
  // see all the college's recruiter POCs and the per-teammate recruiter tracking.
  // Assigned by the Platform Admin (the founding admin is the head by default).
  isCollegeHead      Boolean   @default(false) @map("is_college_head")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  emailVerifiedAt    DateTime? @map("email_verified_at")
  lastLoginAt        DateTime? @map("last_login_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  college        College?             @relation(fields: [collegeId], references: [id])
  refreshTokens  RefreshToken[]
  passwordResets PasswordResetToken[]
  student        Student?
  notifications  Notification[]

  @@index([collegeId])
  @@map("users")
}

enum NotificationType {
  PROFILE_SUBMITTED
  PROFILE_VERIFIED
  PROFILE_REJECTED
  APPLICATION_STAGE_CHANGED
  OFFER_RELEASED
  INTERVIEW_SCHEDULED
  GENERAL
}

// In-app notification for a single recipient user. Tenant column mirrors the
// recipient's college (null for Platform Admin). Email delivery is a separate,
// later concern — this table is the in-app feed only.
model Notification {
  id        String           @id @default(uuid())
  collegeId String?          @map("college_id")
  userId    String           @map("user_id")
  type      NotificationType @default(GENERAL)
  title     String
  body      String?
  link      String?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ─────────────────────────── Phase 4: Alumni network ───────────────────────────

// A college's alumni record. Independent of the Student/User tables — alumni are
// not platform login accounts in V1; this is a CRM-style directory the placement
// cell curates for mentorship, referrals and outreach. collegeId is a bare scalar
// (tenant isolation enforced in the API layer), consistent with Phase 3 tables.
model Alumni {
  id                 String   @id @default(uuid())
  collegeId          String   @map("college_id")
  fullName           String   @map("full_name")
  email              String
  phone              String?
  registerNumber     String?  @map("register_number")
  joiningYear        Int?     @map("joining_year")
  graduationYear     Int      @map("graduation_year")
  course             String?
  branch             String
  currentCompany     String?  @map("current_company")
  currentDesignation String?  @map("current_designation")
  currentLocation    String?  @map("current_location")
  linkedinUrl        String?  @map("linkedin_url")
  isMentor           Boolean  @default(false) @map("is_mentor")
  isHiring           Boolean  @default(false) @map("is_hiring")
  tags               String[]
  notes              String?
  // Self-registration: alumni who signed up via the public portal land here
  // unapproved (isApproved=false) for the placement cell to review. Officer-
  // created records default to approved.
  selfRegistered     Boolean  @default(false) @map("self_registered")
  isApproved         Boolean  @default(true) @map("is_approved")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([collegeId, email])
  @@index([collegeId, graduationYear])
  @@index([collegeId, branch])
  @@map("alumni")
}

enum VerificationStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

model Student {
  id                 String             @id @default(uuid())
  collegeId          String             @map("college_id")
  userId             String             @unique @map("user_id")
  rollNumber         String             @map("roll_number")
  enrollmentNumber   String?            @map("enrollment_number")
  course             String
  branch             String
  graduationYear     Int                @map("graduation_year")
  // Current year of study (1, 2, …) — e.g. MBA II YEAR = 2. Null = not tracked.
  currentYear        Int?               @map("current_year")
  cgpa               Decimal?           @db.Decimal(4, 2)
  activeBacklogs     Int                @default(0) @map("active_backlogs")
  totalBacklogs      Int                @default(0) @map("total_backlogs")
  // Extended profile (employability + eligibility).
  dateOfBirth        DateTime?          @map("date_of_birth")
  gender             String?
  personalEmail      String?            @map("personal_email")
  linkedinUrl        String?            @map("linkedin_url")
  tenthPercentage    Decimal?           @db.Decimal(5, 2) @map("tenth_percentage")
  twelfthPercentage  Decimal?           @db.Decimal(5, 2) @map("twelfth_percentage")
  // Undergraduate degree percentage — relevant for PG students whose main
  // "Percentage" (cgpa) reflects their current/PG course. Separate eligibility gate.
  ugPercentage       Decimal?           @db.Decimal(5, 2) @map("ug_percentage")
  // Semester-wise marks: [{ label, score }] as JSON for flexibility.
  semesterMarks      Json?              @map("semester_marks")

  // Extended profile data collected through the student step-form wizard.
  nationality              String?  @map("nationality")
  panNumber                String?  @map("pan_number")
  currentAddress           String?  @map("current_address")
  permanentAddress         String?  @map("permanent_address")
  city                     String?
  state                    String?
  pinCode                  String?  @map("pin_code")
  fatherName               String?  @map("father_name")
  fatherOccupation         String?  @map("father_occupation")
  fatherPhone              String?  @map("father_phone")
  department               String?
  specialization           String?
  admissionYear            Int?     @map("admission_year")
  currentSemester          Int?     @map("current_semester")
  hasArrearHistory         Boolean? @map("has_arrear_history")
  tenthBoard               String?  @map("tenth_board")
  tenthSchool              String?  @map("tenth_school")
  tenthPassingYear         Int?     @map("tenth_passing_year")
  twelfthBoard             String?  @map("twelfth_board")
  twelfthSchool            String?  @map("twelfth_school")
  twelfthStream            String?  @map("twelfth_stream")
  twelfthPassingYear       Int?     @map("twelfth_passing_year")
  ugCollege                String?  @map("ug_college")
  ugDegree                 String?  @map("ug_degree")
  ugSpecialization         String?  @map("ug_specialization")
  languagesKnown           String?  @map("languages_known")
  communicationSkillRating Int?     @map("communication_skill_rating")
  higherStudiesPlanned     Boolean? @map("higher_studies_planned")
  entrepreneurshipInterest Boolean? @map("entrepreneurship_interest")

  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  verifiedById       String?            @map("verified_by_id")
  verifiedAt         DateTime?          @map("verified_at")
  rejectionReason    String?            @map("rejection_reason")
  profileCompletion  Int                @default(0) @map("profile_completion")
  isActive           Boolean            @default(true) @map("is_active")
  // Set when the student's batch is graduated to Alumni. Graduated students are
  // hidden from the Students list (they live in the Alumni directory now).
  graduatedAt        DateTime?          @map("graduated_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  college         College          @relation(fields: [collegeId], references: [id])
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume          Resume?
  applications    Application[]
  internships     Internship[]

  @@unique([collegeId, rollNumber])
  @@index([collegeId, branch, graduationYear])
  @@map("students")
}

// A student's uploaded résumé PDF. publicSlug is an unguessable capability token:
// the PDF viewer at /r/<slug> is viewable without login while isPublished is true.
model Resume {
  id          String   @id @default(uuid())
  studentId   String   @unique @map("student_id")
  collegeId   String   @map("college_id")
  publicSlug  String   @unique @map("public_slug")
  fileUrl     String   @map("file_url")
  fileName    String   @map("file_name")
  fileSize    Int      @map("file_size")
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([collegeId])
  @@map("resumes")
}

// ─────────────────────────── Phase 3: Companies, Jobs, ATS ───────────────────────────

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum JobType {
  FULL_TIME
  INTERNSHIP
  INTERNSHIP_PPO
}

// Where the role is performed. ONSITE = work from office.
enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
}

// COLLEGE jobs belong to one college (collegeId set, companyId references a
// tenant Company). PLATFORM jobs are posted by a Platform Admin and broadcast to
// the colleges listed in targetCollegeIds (collegeId null, free-text companyName).
enum JobScope {
  COLLEGE
  PLATFORM
}

enum ApplicationStage {
  APPLIED
  VERIFIED
  SHORTLISTED
  ROUND_1
  ROUND_2
  ROUND_3
  HR
  OFFER_RELEASED
  OFFER_ACCEPTED
  JOINED
  REJECTED
  WITHDRAWN
}

enum InterviewResult {
  PENDING
  PASSED
  FAILED
  NO_SHOW
}

// ── Dynamic interview-rounds funnel ──
// A job's rounds are added on demand (Round 1, 2, 3…). Each round is OPEN until
// the officer decides who advances, then DECIDED (read-only history).
enum RoundStatus {
  OPEN
  DECIDED
}

// A single applicant's result within one round.
enum RoundOutcome {
  PENDING
  ADVANCED
  REJECTED
}

enum RoundType {
  APTITUDE
  TECHNICAL
  CODING
  HR
  GROUP_DISCUSSION
  OTHER
}

// Overall progress of an application through the funnel. Drives the student's
// tracking timeline and the officer's applicant lists.
enum ApplicationOutcome {
  APPLIED
  IN_PROGRESS
  SELECTED
  REJECTED
  WITHDRAWN
}

model Company {
  id          String   @id @default(uuid())
  collegeId   String   @map("college_id")
  name        String
  website     String?
  industry    String?
  description String?
  logoUrl     String?  @map("logo_url")
  city        String?
  isActive    Boolean  @default(true) @map("is_active")
  // The officer/admin who registered this recruiter — powers the College Head's
  // per-teammate recruiter tracking. Nullable for pre-existing rows.
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  contacts CompanyContact[]
  jobs     Job[]

  @@unique([collegeId, name])
  @@index([collegeId])
  @@map("companies")
}

model CompanyContact {
  id          String  @id @default(uuid())
  companyId   String  @map("company_id")
  name        String
  designation String?
  email       String
  phone       String?
  isPrimary   Boolean @default(false) @map("is_primary")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("company_contacts")
}

model Job {
  id                  String    @id @default(uuid())
  scope               JobScope  @default(COLLEGE)
  collegeId           String?   @map("college_id")
  targetCollegeIds    String[]  @map("target_college_ids")
  companyId           String?   @map("company_id")
  companyName         String?   @map("company_name")
  title               String
  description         String?
  jobType             JobType   @default(FULL_TIME) @map("job_type")
  workMode            WorkMode? @map("work_mode")
  location            String?
  experienceMin       Int?      @map("experience_min")
  experienceMax       Int?      @map("experience_max")
  ctcMin              Decimal?  @db.Decimal(12, 2) @map("ctc_min")
  ctcMax              Decimal?  @db.Decimal(12, 2) @map("ctc_max")
  eligibleCourses     String[]  @map("eligible_courses")
  eligibleBranches    String[]  @map("eligible_branches")
  minCgpa             Decimal?  @db.Decimal(4, 2) @map("min_cgpa")
  minTenthPercentage  Decimal?  @db.Decimal(5, 2) @map("min_tenth_percentage")
  minTwelfthPercentage Decimal? @db.Decimal(5, 2) @map("min_twelfth_percentage")
  // Minimum undergraduate degree % (checked against Student.ugPercentage).
  minUgPercentage     Decimal?  @db.Decimal(5, 2) @map("min_ug_percentage")
  // Empty = any gender. Otherwise only these genders are eligible.
  eligibleGenders     String[]  @map("eligible_genders")
  maxActiveBacklogs   Int?      @map("max_active_backlogs")
  maxTotalBacklogs    Int?      @map("max_total_backlogs")
  graduationYears     Int[]     @map("graduation_years")
  // Optional uploaded Job Description PDF (Vercel Blob URL) for "quick post" jobs —
  // the officer uploads the company's JD instead of typing a description.
  pdfUrl              String?    @map("pdf_url")
  pdfName            String?    @map("pdf_name")
  // Optional custom application questions: [{ id, label, type, options?, required }].
  // Students answer these at apply time; answers stored on Application.formResponses.
  applicationFormFields Json?   @map("application_form_fields")
  status              JobStatus @default(DRAFT)
  applicationDeadline DateTime? @map("application_deadline")
  publishedAt         DateTime? @map("published_at")
  closedAt            DateTime? @map("closed_at")
  createdById         String    @map("created_by_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  company      Company?      @relation(fields: [companyId], references: [id])
  applications Application[]
  rounds       JobRound[]

  @@index([collegeId, status])
  @@index([companyId])
  @@index([scope, status])
  @@map("jobs")
}

model Application {
  id              String           @id @default(uuid())
  collegeId       String           @map("college_id")
  jobId           String           @map("job_id")
  studentId       String           @map("student_id")
  stage           ApplicationStage @default(APPLIED)
  // New rounds-funnel status. `stage` is kept as a legacy bridge for analytics/
  // reports (stamped OFFER_ACCEPTED/REJECTED on select/reject); the UI uses status.
  status          ApplicationOutcome @default(APPLIED)
  appliedAt       DateTime         @default(now()) @map("applied_at")
  rejectedAt      DateTime?        @map("rejected_at")
  rejectionReason String?          @map("rejection_reason")
  offerCtc        Decimal?         @db.Decimal(12, 2) @map("offer_ctc")
  // Optional offer letter (Vercel Blob URL) uploaded when a student is selected.
  offerLetterUrl  String?          @map("offer_letter_url")
  notes           String?
  // Answers to the job's custom application questions: { [fieldId]: value }.
  formResponses   Json?            @map("form_responses")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  job          Job                       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  student      Student                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  stageHistory ApplicationStageHistory[]
  interviews   InterviewRound[]
  rounds       ApplicationRound[]

  @@unique([jobId, studentId])
  @@index([collegeId, stage])
  @@index([collegeId, status])
  @@index([studentId])
  @@map("applications")
}

// A dynamic interview round on a job (Round 1, 2, 3…). Officer adds these on
// demand; each carries an optional schedule that drives the "results pending" alert.
model JobRound {
  id          String      @id @default(uuid())
  jobId       String      @map("job_id")
  collegeId   String      @map("college_id")
  seq         Int
  title       String
  roundType   RoundType?  @map("round_type")
  description String?
  scheduledAt DateTime?   @map("scheduled_at")
  status      RoundStatus @default(OPEN)
  createdById String      @map("created_by_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  job          Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  participants ApplicationRound[]

  // Scoped by college so each college runs its own round numbering on a shared
  // PLATFORM-broadcast job (as well as its own college jobs).
  @@unique([jobId, collegeId, seq])
  @@index([collegeId, status])
  @@map("job_rounds")
}

// One applicant's participation + result in one round.
model ApplicationRound {
  id            String       @id @default(uuid())
  applicationId String       @map("application_id")
  roundId       String       @map("round_id")
  outcome       RoundOutcome @default(PENDING)
  decidedAt     DateTime?    @map("decided_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  round       JobRound    @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([applicationId, roundId])
  @@index([roundId, outcome])
  @@map("application_rounds")
}

model ApplicationStageHistory {
  id            String           @id @default(uuid())
  applicationId String           @map("application_id")
  fromStage     ApplicationStage? @map("from_stage")
  toStage       ApplicationStage  @map("to_stage")
  changedById   String            @map("changed_by_id")
  note          String?
  createdAt     DateTime          @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_stage_history")
}

model InterviewRound {
  id            String          @id @default(uuid())
  applicationId String          @map("application_id")
  collegeId     String          @map("college_id")
  roundName     String          @map("round_name")
  scheduledAt   DateTime?       @map("scheduled_at")
  mode          String?
  location      String?
  result        InterviewResult @default(PENDING)
  feedback      String?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("interview_rounds")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Append-only audit trail for privileged actions and PII exports. No FK to User
// so logs survive user deletion. collegeId is null for platform-level actions.
model AuditLog {
  id         String   @id @default(uuid())
  collegeId  String?  @map("college_id")
  actorId    String   @map("actor_id")
  actorRole  String   @map("actor_role")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([collegeId, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

// ─────────────────────────── Internships ───────────────────────────

enum InternshipStatus {
  PENDING
  VERIFIED
  REJECTED
}

// A student-submitted internship record. Students fill in structured details;
// the placement cell verifies them. Company is free-text (interns may have worked
// anywhere, not only campus recruiters), mirroring the Alumni directory pattern.
model Internship {
  id              String           @id @default(uuid())
  collegeId       String           @map("college_id")
  studentId       String           @map("student_id")
  companyName     String           @map("company_name")
  role            String
  employmentType  EmploymentType?  @map("employment_type")
  domain          String?
  skills          String?
  location        String
  isPaid          Boolean          @default(false) @map("is_paid")
  stipend         Decimal?         @db.Decimal(12, 2)
  startDate       DateTime?        @map("start_date")
  endDate         DateTime?        @map("end_date")
  // Converted into a pre-placement offer (PPO).
  isPpo           Boolean          @default(false) @map("is_ppo")
  description     String?
  // Point-of-contact at the company (students self-report internships they found).
  pocName         String           @map("poc_name")
  pocEmail        String           @map("poc_email")
  pocPhone        String           @map("poc_phone")
  certificateUrl  String?          @map("certificate_url")
  status          InternshipStatus @default(PENDING)
  verifiedById    String?          @map("verified_by_id")
  verifiedAt      DateTime?        @map("verified_at")
  rejectionReason String?          @map("rejection_reason")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([collegeId, status])
  @@index([studentId])
  @@map("internships")
}
